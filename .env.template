# =============================================================================
# GdeiAssistant 环境变量模板（可提交到 Git）
#
# 【开源用户请阅读】
# 请将此文件复制并重命名为 .env，然后填入你自己的数据库、Redis、JWT 等
# 真实信息。勿将 .env 提交到 Git。
# 操作示例：cp .env.template .env  再编辑 .env 填入真实配置。
# =============================================================================

# MySQL（开发用 localhost，生产 Docker 内用 mysql）
DB_NAME=gdeiassistant
DB_PASSWORD=YOUR_SECURE_DB_PASSWORD
DB_HOST=localhost
DB_PORT=3306

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DATABASE=gdeiassistant

# 必填：JWT 签名密钥，建议 ≥32 字符随机串
JWT_SECRET=YOUR_SECURE_JWT_SECRET_AT_LEAST_32_CHARS

# ---------- 以下为生产/可选，docker-compose-prod 会用到 ----------
# MYSQL_ROOT_PASSWORD=YOUR_SECURE_MYSQL_PASSWORD
# EMAIL_SMTP_HOST=
# WECHAT_APP_APPID=
# R2_ENDPOINT=
# ...
