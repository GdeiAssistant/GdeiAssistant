# =============================================================================
# GdeiAssistant 环境变量模板（可提交到 Git）
# 使用前复制为 .env；Docker Compose 与 Spring Boot 统一读取该文件。
# 模板可提交到 Git，真实凭据不要提交。
# 说明：
# 1. 带默认值的变量通常可保持不变
# 2. 标注“必填”的变量需要提供真实值
# 3. 标注“按需”的变量仅在启用对应能力时配置
# =============================================================================

# -----------------------------------------------------------------------------
# 1. 运行入口端口
# SERVER_PORT 用于本地 ./gradlew bootRun
# *_EXPOSE_PORT 用于 Docker 对宿主机暴露的端口
# 端口变量为可选覆盖项，仅在端口冲突时调整
# -----------------------------------------------------------------------------
SERVER_PORT=8080
BACKEND_EXPOSE_PORT=8080
FRONTEND_EXPOSE_PORT=5173
FRONTEND_STAGING_EXPOSE_PORT=8088
FRONTEND_PROD_EXPOSE_PORT=80
MYSQL_EXPOSE_PORT=3306
REDIS_EXPOSE_PORT=6379
MONGO_EXPOSE_PORT=27017

# -----------------------------------------------------------------------------
# 2. Spring / 本地直跑数据库连接
# 本地 bootRun 通常使用 localhost；Docker Compose 内部会自动改为 mysql/redis/mongodb
# 本地运行通常至少需要正确配置 DB_PASSWORD 和 JWT_SECRET
# -----------------------------------------------------------------------------

# Spring Profile：可选；统一使用 development / staging / production
SPRING_PROFILES_ACTIVE=development

# MySQL：本地直跑后端通常需要；使用 Docker Compose 时默认走 root@localhost
# 演示 / 生产若接外部 MySQL，可改 DB_USERNAME / DB_JDBC_PARAMS，或直接覆盖三套 JDBC URL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gdeiassistant
DB_NAME_LOG=gdeiassistant_log
DB_NAME_DATA=gdeiassistant_data
DB_USERNAME=root
DB_PASSWORD=
DB_JDBC_PARAMS=useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_JDBC_URL_APP=
DB_JDBC_URL_LOG=
DB_JDBC_URL_DATA=

# Redis：按需；外部托管 Redis 如要求 ACL/TLS，可配置 REDIS_USERNAME / REDIS_SSL_ENABLED
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_SSL_ENABLED=false

# MongoDB：按需；本地默认走 host/port/database
# 如使用外部托管 MongoDB，优先填写完整连接串 MONGO_URI（包含账号、密码、TLS、数据库）
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DATABASE=gdeiassistant
MONGO_URI=

# 必填：JWT 签名密钥，建议至少 32 位随机串
JWT_SECRET=

# 必填（生产）：定时任务触发密钥，用于 /cron/* 端点鉴权
CRON_SECRET=

# -----------------------------------------------------------------------------
# 3. 前端运行时
# 开发环境默认指向宿主机后端；生产镜像默认使用 /api
# 如需调整宿主机后端端口，应同步更新 VITE_APP_BASE_API
# CORS_ALLOWED_ORIGIN_PATTERNS 仅在前后端跨域部署时需要配置，多个来源用英文逗号分隔
# 本地联调通常可保留默认值
# -----------------------------------------------------------------------------

# 前端请求后端的基础地址
VITE_APP_BASE_API=http://localhost:8080/api

# 培优 / 外部页面地址：按需
VITE_PE_EXTERNAL_URL=

# CORS 白名单：仅前后端跨域部署时调整；同域反向代理通常无需修改
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# -----------------------------------------------------------------------------
# 4. 邮件、微信、对象存储、AI、短信等扩展能力
# 未启用的能力可保持空值
# -----------------------------------------------------------------------------

# 邮件：按需；启用邮箱验证码、反馈或工单通知时配置
# 常用必填项：EMAIL_SMTP_HOST / EMAIL_SMTP_USERNAME / EMAIL_SMTP_PASSWORD
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_FEEDBACK=
EMAIL_TICKET=

# R2 / 对象存储：按需；启用文件上传时配置
# 常用必填项：R2_ENDPOINT / R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY
# R2_BUCKET_NAME 有默认值；R2_CUSTOM_DOMAIN 仅在自定义访问域名时填写
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=gdeiassistant-userdata
R2_CUSTOM_DOMAIN=

# -----------------------------------------------------------------------------
# AI OCR（验证码 / 数字识别）
# AI_OCR_PROVIDER 可选值：deepseek / claude / openai / gemini / doubao
# 默认值为 deepseek；留空时后端同样按 deepseek 处理
# 仅配置当前选中 provider 对应的 API Key；其他 provider 可留空
# model / *_BASE_URL / *_API_URL 为可选覆盖项；留空时使用项目默认值
# -----------------------------------------------------------------------------
AI_OCR_PROVIDER=deepseek

# OpenAI：仅在 AI_OCR_PROVIDER=openai 时必须填写 OPENAI_API_KEY
OPENAI_API_KEY=
OPENAI_OCR_MODEL=gpt-4.1-mini

# Gemini：仅在 AI_OCR_PROVIDER=gemini 时必须填写 GEMINI_API_KEY
GEMINI_API_KEY=
GEMINI_OCR_MODEL=gemini-2.0-flash

# Claude：仅在 AI_OCR_PROVIDER=claude 时必须填写 CLAUDE_API_KEY
CLAUDE_API_KEY=
CLAUDE_OCR_MODEL=claude-sonnet-4-20250514
CLAUDE_OCR_API_URL=https://api.anthropic.com/v1/messages

# DeepSeek：仅在 AI_OCR_PROVIDER=deepseek 时必须填写 DEEPSEEK_API_KEY
DEEPSEEK_API_KEY=
DEEPSEEK_OCR_MODEL=deepseek-chat
DEEPSEEK_OCR_BASE_URL=https://api.deepseek.com/v1

# 豆包：仅在 AI_OCR_PROVIDER=doubao 时必须填写 DOUBAO_API_KEY
DOUBAO_API_KEY=
DOUBAO_OCR_MODEL=doubao-1.5-vision-pro-32k
DOUBAO_OCR_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# -----------------------------------------------------------------------------
# 短信：按需；只有启用短信验证码/通知时才需要
# SMS_PROVIDER 可选值：tencent / aliyun / huawei
# 仅配置当前选中 provider 对应变量；其他 provider 可留空
# -----------------------------------------------------------------------------
SMS_PROVIDER=tencent

# 腾讯云短信：仅在 SMS_PROVIDER=tencent 时填写
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_REGION=ap-guangzhou
TENCENT_SMS_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_CHINA=
TENCENT_SMS_TEMPLATE_GLOBAL=

# 阿里云短信：仅在 SMS_PROVIDER=aliyun 时填写
ALIYUN_SMS_USERID=
ALIYUN_SMS_ACCESSKEY_ID=
ALIYUN_SMS_ACCESSKEY_SECRET=
ALIYUN_SMS_CHINA_TEMPLATE=
ALIYUN_SMS_GLOBAL_TEMPLATE=

# 华为云短信：仅在 SMS_PROVIDER=huawei 时填写
HUAWEI_SMS_APP_KEY=
HUAWEI_SMS_APP_SECRET=
HUAWEI_SMS_ENDPOINT=https://smsapi.cn-north-4.myhuaweicloud.com:443
HUAWEI_SMS_SENDER=
HUAWEI_SMS_SIGNATURE=
HUAWEI_SMS_TEMPLATE_CHINA=
HUAWEI_SMS_TEMPLATE_GLOBAL=

# 灰度主题：可选；0 表示关闭
THEME_GRAYSCALE=0

# 敏感字段加密：staging / production 环境必须启用（ENCRYPT_ENABLE=true），否则拒绝启动
# 本地 development 默认关闭；启用时必须同时填写 ENCRYPT_PRIVATE_KEY
ENCRYPT_ENABLE=false
ENCRYPT_PRIVATE_KEY=

# Docker 网络名：可选；仅在需要自定义 Docker Compose 网络时调整
DEV_COMPOSE_NETWORK_NAME=gdei-dev
STAGING_COMPOSE_NETWORK_NAME=gdei-staging
PROD_COMPOSE_NETWORK_NAME=gdei-network
